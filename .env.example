NEXT_PUBLIC_GRAPHQL_ENDPOINT=https://localhost:8080/v1/graphql
NEXT_PUBLIC_GA_TAG_ID=G-1234567890
WEBHOOK_SECRET=your_webhook_secret_here

# GitHub Token for GHCR package listing (requires read:packages scope)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Secret key for signing OG image URLs (prevents API misuse)
# Generate a secure random string for production
OG_SECRET=your-og-secret-change-in-production

# Secret token for Logo.dev provider logos used by the message header analyzer
# Keep this server-side only
# LOGO_DEV_SECRET=your_logo_dev_secret_here

# Sentry error tracking
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.us.sentry.io/xxx

# Enable react-grab MCP browser tool (set to "1" to enable, never in production)
# NEXT_PUBLIC_REACT_GRAB=1
